
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// User Model
// ------------------------------------------------------
// Represents the "User" table in the PostgreSQL database.
// Stores basic authentication details (email, password).
model User {
  id        Int        @id @default(autoincrement()) // Primary Key
  email     String     @unique                       // Must be unique for login
  password  String                                 // Hashed password
  templates Template[]                               // A user can create many templates
  posts     Post[]                                   // A user can author many posts
  createdAt DateTime   @default(now())               // Auto-generated timestamp
  updatedAt DateTime   @updatedAt                    // Auto-updated timestamp
}

// ------------------------------------------------------
// Template Model (Visual Blog Builder Layouts)
// ------------------------------------------------------
// Stores the drag-and-drop layout schemas designed by Admins
model Template {
  id          Int      @id @default(autoincrement())
  name        String                                // Name of the layout (e.g., Default Single Post)
  type        String                                // e.g., "single_post" or "archive"
  category    String?                               // Optional: For category-specific layouts
  status      String   @default("draft")            // "draft" or "published"
  layoutJson  Json                                  // Storing the layout as structured JSON
  authorId    Int                                   // Admin user who created it
  author      User     @relation(fields: [authorId], references: [id])
  version     Int      @default(1)                  // Layout version tracking
  history     TemplateHistory[]                     // Previous versions of this layout
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------
// TemplateHistory Model (Versioning)
// ------------------------------------------------------
// Stores previous versions of templates allowing for rollback
model TemplateHistory {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  layoutJson  Json
  updatedBy   Int      // User ID who made the edit
  createdAt   DateTime @default(now())
}

// ------------------------------------------------------
// Post Model (Dynamic Blog Data)
// ------------------------------------------------------
// Actual blog content to be injected into layouts
model Post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  imageUrl    String?
  status      String   @default("published")
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
